# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file — it is in .gitignore.
# ══════════════════════════════════════════════════════════════════════════════

# ── Google Cloud / Vertex AI ──────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
TUNED_MODEL_ENDPOINT_v4=projects/YOUR_PROJECT_NUMBER/locations/us-central1/endpoints/YOUR_ENDPOINT_ID

# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=my-super-secret-token-123
INFLUX_ORG=boiler_org
INFLUX_BUCKET=boiler_data

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PATH=./chroma_db

# ── OpenAI (used for RAGAS evaluation only) ───────────────────────────────────
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE

# ── Chronos Forecasting ───────────────────────────────────────────────────────
# Change CHRONOS_DEVICE to "cuda" if a GPU is available for ~4x faster refresh.
CHRONOS_MODEL=amazon/chronos-t5-small
CHRONOS_DEVICE=cpu
CHRONOS_REFRESH_INTERVAL=30
CHRONOS_PREDICTION_LENGTH=20
CHRONOS_STEP_INTERVAL=10
CHRONOS_HISTORY_MINUTES=20

# ── Redis Chat Cache ──────────────────────────────────────────────────────────
# Dev: local Docker Redis (docker-compose.yml has the redis service)
# Prod: replace with Upstash URL → rediss://default:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379/0
REDIS_TLS=false
CHAT_HISTORY_MAX_TURNS=20
CHAT_HISTORY_TTL_SECONDS=86400
CHAT_SUMMARY_THRESHOLD=20
