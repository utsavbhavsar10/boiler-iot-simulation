    {
      "id": 20, "type": "row",
      "title": "🔥 BOILER — Combustion & Desuperheater",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 }
    },

    {
      "id": 21, "type": "timeseries",
      "title": "Flue Gas Temperature (°C)",
      "description": "Normal: 120–140 °C  |  Warning: 110–160 °C  |  Critical: 100–175 °C",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 35 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"boiler_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r[\"_measurement\"] == \"boiler_sensors\") |> filter(fn: (r) => r[\"sensor\"] == \"flue_gas_temp\") |> filter(fn: (r) => r[\"_field\"] == \"value\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> yield(name: \"mean\")"
      }],
