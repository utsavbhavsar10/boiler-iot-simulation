            { "color": "red",    "value": null },
            { "color": "yellow", "value": 750  },
            { "color": "green",  "value": 800  },
            { "color": "yellow", "value": 1050 },
            { "color": "red",    "value": 1100 }
          ]},
          "custom": { "lineWidth": 2, "fillOpacity": 8, "thresholdsStyle": { "mode": "line" } }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 14, "type": "timeseries",
      "title": "Feedwater Pressure (MPa)",
      "description": "Normal: 18.0–20.0 MPa  |  Warning: 17.0–21.0 MPa  |  Critical: 16.0–22.0 MPa",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 25 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"boiler_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r[\"_measurement\"] == \"boiler_sensors\") |> filter(fn: (r) => r[\"sensor\"] == \"feedwater_pressure\") |> filter(fn: (r) => r[\"_field\"] == \"value\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> yield(name: \"mean\")"
