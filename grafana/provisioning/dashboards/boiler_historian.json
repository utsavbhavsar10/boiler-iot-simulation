{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB — Boiler Historian",
      "description": "InfluxDB 2.x Flux datasource for boiler_data bucket",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__elements": {},
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",      "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb",   "name": "InfluxDB",     "version": "1.0.0"  },
    { "type": "panel",      "id": "stat",       "name": "Stat",         "version": ""       },
    { "type": "panel",      "id": "timeseries", "name": "Time series",  "version": ""       },
    { "type": "panel",      "id": "table",      "name": "Table",        "version": ""       }
  ],
  "description": "Real-time boiler, turbine, and chimney historian with warning/critical threshold coloring. Data from InfluxDB via MQTT pipeline.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["boiler", "iot", "historian", "chronos"],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Boiler IoT Historian Dashboard",
  "uid": "boiler-historian-v1",
  "version": 1,
  "weekStart": "",

  "panels": [

    {
      "id": 1, "type": "row",
      "title": "🔥 BOILER — Current Status (Live Values)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "id": 2, "type": "stat",
      "title": "Main Steam Temp Boiler",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"boiler_data\") |> range(start: -2m) |> filter(fn: (r) => r[\"_measurement\"] == \"boiler_sensors\") |> filter(fn: (r) => r[\"sensor\"] == \"main_steam_temp_boiler\") |> filter(fn: (r) => r[\"_field\"] == \"value\") |> last()"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 555 },
            { "color": "red", "value": 565 }
          ]}
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "text": { "valueSize": 28 } }
    },

    {
      "id": 3, "type": "stat",
      "title": "Main Steam Pressure Boiler",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"boiler_data\") |> range(start: -2m) |> filter(fn: (r) => r[\"_measurement\"] == \"boiler_sensors\") |> filter(fn: (r) => r[\"sensor\"] == \"main_steam_pressure_boiler\") |> filter(fn: (r) => r[\"_field\"] == \"value\") |> last()"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "pressurembar",
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 18.0 },
            { "color": "red", "value": 18.5 }
          ]}
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "text": { "valueSize": 28 } }
    },

    {
      "id": 4, "type": "stat",
      "title": "Main Steam Flow",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"boiler_data\") |> range(start: -2m) |> filter(fn: (r) => r[\"_measurement\"] == \"boiler_sensors\") |> filter(fn: (r) => r[\"sensor\"] == \"main_steam_flow\") |> filter(fn: (r) => r[\"_field\"] == \"value\") |> last()"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "suffix": " t/h",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 700 },
            { "color": "green", "value": 750 }
          ]}
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "text": { "valueSize": 28 } }
    },

    {
      "id": 5, "type": "stat",
      "title": "Feedwater Temp",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"boiler_data\") |> range(start: -2m) |> filter(fn: (r) => r[\"_measurement\"] == \"boiler_sensors\") |> filter(fn: (r) => r[\"sensor\"] == \"feedwater_temp\") |> filter(fn: (r) => r[\"_field\"] == \"value\") |> last()"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 295 },
            { "color": "red", "value": 305 }
          ]}
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "text": { "valueSize": 28 } }
    },

    {
      "id": 50, "type": "stat",
      "title": "Oxygen Level (Boiler)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"boiler_data\") |> range(start: -2m) |> filter(fn: (r) => r[\"_measurement\"] == \"boiler_sensors\") |> filter(fn: (r) => r[\"sensor\"] == \"oxygen_level\") |> filter(fn: (r) => r[\"_field\"] == \"value\") |> last()"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 2.0 },
            { "color": "green", "value": 3.0 }
          ]}
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "text": { "valueSize": 28 } }
    },

    {
      "id": 51, "type": "stat",
      "title": "Flue Gas Temp",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"boiler_data\") |> range(start: -2m) |> filter(fn: (r) => r[\"_measurement\"] == \"boiler_sensors\") |> filter(fn: (r) => r[\"sensor\"] == \"flue_gas_temp\") |> filter(fn: (r) => r[\"_field\"] == \"value\") |> last()"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 160 },
            { "color": "red", "value": 175 }
          ]}
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "text": { "valueSize": 28 } }
    },

    {
      "id": 10, "type": "row",
      "title": "🌡️ BOILER — Temperature Monitoring",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },

    {
      "id": 6, "type": "timeseries",
      "title": "Main Steam Temperature — Boiler (°C)",
      "description": "Normal: 535–545 °C  |  Warning: 525–555 °C  |  Critical: 520–565 °C",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"boiler_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r[\"_measurement\"] == \"boiler_sensors\") |> filter(fn: (r) => r[\"sensor\"] == \"main_steam_temp_boiler\") |> filter(fn: (r) => r[\"_field\"] == \"value\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> yield(name: \"mean\")"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "celsius",
          "min": 510, "max": 580,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",         "value": null  },
            { "color": "dark-orange", "value": 520   },
            { "color": "yellow",      "value": 525   },
            { "color": "green",       "value": 535   },
            { "color": "yellow",      "value": 545   },
            { "color": "dark-orange", "value": 555   },
            { "color": "red",         "value": 565   }
          ]},
          "custom": { "lineWidth": 2, "fillOpacity": 8, "thresholdsStyle": { "mode": "line" } }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 7, "type": "timeseries",
      "title": "Reheat Steam Temperature — Boiler (°C)",
      "description": "Normal: 535–545 °C  |  Warning: 525–555 °C  |  Critical: 520–565 °C",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"boiler_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r[\"_measurement\"] == \"boiler_sensors\") |> filter(fn: (r) => r[\"sensor\"] == \"reheat_steam_temp_boiler\") |> filter(fn: (r) => r[\"_field\"] == \"value\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> yield(name: \"mean\")"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "celsius",
          "min": 510, "max": 580,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",         "value": null },
            { "color": "dark-orange", "value": 520  },
            { "color": "yellow",      "value": 525  },
            { "color": "green",       "value": 535  },
            { "color": "yellow",      "value": 545  },
            { "color": "dark-orange", "value": 555  },
            { "color": "red",         "value": 565  }
          ]},
          "custom": { "lineWidth": 2, "fillOpacity": 8, "thresholdsStyle": { "mode": "line" } }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 8, "type": "timeseries",
      "title": "Main Steam Pressure — Boiler (MPa)",
      "description": "Normal: 16.0–17.5 MPa  |  Warning: 15.5–18.0 MPa  |  Critical: 15.0–18.5 MPa",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"boiler_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r[\"_measurement\"] == \"boiler_sensors\") |> filter(fn: (r) => r[\"sensor\"] == \"main_steam_pressure_boiler\") |> filter(fn: (r) => r[\"_field\"] == \"value\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> yield(name: \"mean\")"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none",
          "suffix": " MPa",
          "decimals": 2,
          "min": 14.5, "max": 19.0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",         "value": null  },
            { "color": "dark-orange", "value": 15.0  },
            { "color": "yellow",      "value": 15.5  },
            { "color": "green",       "value": 16.0  },
            { "color": "yellow",      "value": 17.5  },
            { "color": "dark-orange", "value": 18.0  },
            { "color": "red",         "value": 18.5  }
          ]},
          "custom": { "lineWidth": 2, "fillOpacity": 8, "thresholdsStyle": { "mode": "line" } }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 9, "type": "timeseries",
      "title": "Main Steam Flow (t/h)",
      "description": "Normal: 800–1000 t/h  |  Warning: 750–1050 t/h  |  Critical: 700–1100 t/h",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"boiler_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r[\"_measurement\"] == \"boiler_sensors\") |> filter(fn: (r) => r[\"sensor\"] == \"main_steam_flow\") |> filter(fn: (r) => r[\"_field\"] == \"value\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> yield(name: \"mean\")"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none",
          "suffix": " t/h",
          "min": 650, "max": 1150,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": null },
            { "color": "yellow", "value": 750  },
            { "color": "green",  "value": 800  },
            { "color": "yellow", "value": 1050 },
            { "color": "red",    "value": 1100 }
          ]},
          "custom": { "lineWidth": 2, "fillOpacity": 8, "thresholdsStyle": { "mode": "line" } }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
